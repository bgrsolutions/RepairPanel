# ==============================================================================
# IRONCore RepairPanel — Environment Configuration
# ==============================================================================
# Copy this file to .env and adjust values for your environment.
# All variables have sensible defaults; only SECRET_KEY and DATABASE_URL
# are strictly required for production.
# ==============================================================================

# --- Core App -----------------------------------------------------------------
FLASK_APP=manage.py
FLASK_ENV=production
SECRET_KEY=change_this
DATABASE_URL=postgresql://ironcore:ironcore@127.0.0.1:5432/ironcore

# --- Locale & Timezone --------------------------------------------------------
BABEL_DEFAULT_LOCALE=en
BABEL_DEFAULT_TIMEZONE=UTC
SUPPORTED_LOCALES=en,es
TIMEZONE=Europe/Madrid

# --- Branch / Upload ----------------------------------------------------------
DEFAULT_BRANCH_CODE=HQ
UPLOAD_ROOT=uploads
MAX_CONTENT_LENGTH=10485760

# --- Intake -------------------------------------------------------------------
DEFAULT_INTAKE_DISCLAIMER_TEXT=I confirm the provided details are accurate and accept the intake terms.

# --- SLA & Tax ----------------------------------------------------------------
DEFAULT_TICKET_SLA_DAYS=5
DEFAULT_IGIC_RATE=0.07

# --- Email (SMTP) -------------------------------------------------------------
# MAIL_TRANSPORT: "log" (dev, writes to stdout) or "smtp" (production)
MAIL_TRANSPORT=log
MAIL_ENABLED=false
MAIL_SERVER=smtp.yourprovider.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=yourpassword
MAIL_DEFAULT_SENDER=your@email.com
MAIL_DEFAULT_SENDER_NAME=IRONCore RepairPanel
MAIL_DEFAULT_REPLY_TO=
MAIL_SMTP_TIMEOUT=10

# --- IMEICheck API (imeicheck.net) -------------------------------------------
# Set IMEICHECK_ENABLED=true and provide an API key to enable IMEI lookups
# during device intake. When disabled, staff can still enter details manually.
# Docs: https://app.theneo.io/webanite/imeicheck-net/api-reference
IMEICHECK_ENABLED=false
IMEICHECK_API_KEY=your_api_key_here
IMEICHECK_API_URL=https://api.imeicheck.net
IMEICHECK_BASE_URL=https://imeicheck.net/api
# Service ID determines the type of check. Use GET /v1/services to list
# available services for your account. Common IDs: 12 = Apple Info, etc.
IMEICHECK_SERVICE_ID=12
IMEICHECK_TIMEOUT=10
# Optional: brand-aware service mapping (JSON). Maps brand names to service IDs.
# When a brand hint is provided, the matching service ID is used automatically.
# Keys are case-insensitive. Use "default" as a catch-all fallback.
# Example: {"apple": 12, "samsung": 3, "default": 1}
#IMEICHECK_SERVICE_MAP={"apple": 12, "samsung": 3, "default": 1}

# --- Device Security ----------------------------------------------------------
# Key used to encrypt stored device unlock codes (defaults to SECRET_KEY)
DEVICE_UNLOCK_KEY=

# --- Optional / Future (Redis + Celery) ---------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
